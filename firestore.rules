rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Properties: public read, authenticated write
    match /properties/{propertyId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Hero sections: public read for active, authenticated write
    match /hero_sections/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // About content: public read, authenticated write
    match /about_content/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // About stats: public read, authenticated write
    match /about_stats/{statId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Contact info: public read, authenticated write
    match /contact_info/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Contact submissions: public create, authenticated read/update/delete
    match /contact_submissions/{submissionId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Site settings: public read, authenticated write
    match /site_settings/{docId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
